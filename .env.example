# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace-with-random-32-character-secret

# Admin portal credentials (change before going live)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-production

# Hotel portal credentials (move to DB in production — see PRODUCTION_CHECKLIST.md)
HOTEL_HTL001_PASS=demo123
HOTEL_HTL002_PASS=demo123

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Get from https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Ship&Co ───────────────────────────────────────────────────────────────────
# Get from https://app.shipandco.com/settings/api
# Leave blank to use mock labels (demo mode)
SHIPCO_API_KEY=
SHIPCO_API_BASE_URL=https://app.shipandco.com/api/v1

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave blank to log emails to console instead of sending
# See SMTP_SETUP.md for provider setup guides
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=BondEx <noreply@bondex.jp>

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google Places (optional) ──────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=
